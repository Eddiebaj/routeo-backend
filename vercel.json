{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron-push?job=garbage",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron-push?job=garbage",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron-push?job=gameday",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron-push?job=lrt",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron-push?job=departures",
      "schedule": "0 11 * * 1-5"
    },
    {
      "path": "/api/cron-push?job=disruptions",
      "schedule": "*/15 6-23 * * *"
    }
  ]
}